---
layout: compress
swcache: true
---

{% assign search_entries = '' | split: '' %}

{% for post in site.posts %}
  {% capture content -%}{% include post-summary.html full_text=true %}{%- endcapture -%}
  {% capture summary -%}{% include post-summary.html max_length=240 %}{%- endcapture -%}
  {% assign post_lang = post.lang | default: 'en' %}
  {% assign post_key = post.translation_key | default: post.url %}

  {% capture entry %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "categories": {{ post.categories | join: ', ' | jsonify }},
    "tags": {{ post.tags | join: ', ' | jsonify }},
    "date": {{ post.date | jsonify }},
    "lang": {{ post_lang | jsonify }},
    "translation_key": {{ post_key | jsonify }},
    "summary": {{ summary | jsonify }},
    "content": {{ content | jsonify }}
  }
  {% endcapture %}

  {% assign search_entries = search_entries | push: entry %}
{% endfor %}

[
  {{ search_entries | join: ',' }}
]
