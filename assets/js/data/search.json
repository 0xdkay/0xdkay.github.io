---
layout: compress
swcache: true
---

{% assign search_entries = '' | split: '' %}

{% for topic in site.data.topics %}
  {% assign topic_url = '/topics/' | append: topic.slug | append: '/' %}
  {% capture content -%}
    {{ topic.label }}
    {{ topic.short_label }}
    {{ topic.slug }}
    {{ topic.description }}
    {{ topic.keywords }}
    {{ topic_url }}
  {%- endcapture -%}

  {% capture entry %}
  {
    "title": {{ topic.label | jsonify }},
    "url": {{ topic_url | relative_url | jsonify }},
    "type": "Topic",
    "categories": "Topic",
    "tags": "Research Area",
    "keywords": {{ topic.keywords | default: '' | jsonify }},
    "meta": "Research Area",
    "date": "",
    "lang": "en",
    "translation_key": {{ topic_url | jsonify }},
    "summary": {{ topic.description | jsonify }},
    "content": {{ content | strip | jsonify }}
  }
  {% endcapture %}

  {% assign search_entries = search_entries | push: entry %}
{% endfor %}

{% for post in site.posts %}
  {% capture content -%}{% include post-summary.html post=post full_text=true %}{%- endcapture -%}
  {% capture summary -%}{% include post-summary.html post=post max_length=240 %}{%- endcapture -%}
  {% assign post_lang = post.lang | default: 'en' %}
  {% assign post_key = post.translation_key | default: post.url %}
  {% assign post_keywords = post.tags | join: ' ' %}
  {% if post.keywords %}
    {% assign post_keywords = post_keywords | append: ' ' | append: post.keywords %}
  {% endif %}

  {% capture entry %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "type": "Blog",
    "categories": {{ post.categories | join: ', ' | jsonify }},
    "tags": {{ post.tags | join: ', ' | jsonify }},
    "keywords": {{ post_keywords | strip | jsonify }},
    "date": {{ post.date | jsonify }},
    "lang": {{ post_lang | jsonify }},
    "translation_key": {{ post_key | jsonify }},
    "summary": {{ summary | jsonify }},
    "content": {{ content | strip | truncate: 3500 | jsonify }}
  }
  {% endcapture %}

  {% assign search_entries = search_entries | push: entry %}
{% endfor %}

{% for year_group in site.data.publications %}
  {% for item in year_group.papers %}
    {% assign generated_item_anchor = year_group.year | append: '-' | append: forloop.index | append: '-' | append: item.title | slugify %}
    {% assign item_anchor = item.id | default: generated_item_anchor %}
    {% assign item_url = '/publications/#' | append: item_anchor %}
    {% assign item_topics = item.topics | default: empty %}
    {% include entry-date-vars.html date=item.date year=year_group.year %}
    {% assign item_topic_labels = '' | split: '' %}
    {% assign item_keywords = item.keywords | default: '' %}
    {% for topic_slug in item_topics %}
      {% assign topic_match = site.data.topics | where: 'slug', topic_slug | first %}
      {% assign topic_label = topic_slug %}
      {% if topic_match %}
        {% assign topic_label = topic_match.short_label | default: topic_match.label %}
      {% endif %}
      {% assign item_topic_labels = item_topic_labels | push: topic_label %}
    {% endfor %}
    {% capture item_meta -%}{{ item.venue }}{% if entry_date_display %} · {{ entry_date_display }}{% endif %}{%- endcapture -%}
    {% capture content -%}
      {{ item.title }}
      {{ item.authors | strip_html }}
      {{ item.venue }}
      {{ item.date }}
      {{ entry_date_display }}
      {{ entry_date_iso }}
      {{ item_topics | join: ' ' }}
      {{ item_topic_labels | join: ' ' }}
      {{ item_keywords }}
      {{ item_url }}
      {% for link in item.links %}{{ link.label }} {{ link.type }} {{ link.url }} {% endfor %}
      {% for media in item.media %}{{ media.label }} {{ media.url }} {% endfor %}
    {%- endcapture -%}

    {% capture entry %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item_url | relative_url | jsonify }},
      "type": "Paper",
      "categories": "Paper",
      "tags": {{ item_topic_labels | join: ', ' | jsonify }},
      "keywords": {{ item_keywords | jsonify }},
      "meta": {{ item_meta | strip | jsonify }},
      "date": {{ entry_date_iso | jsonify }},
      "lang": "en",
      "translation_key": {{ item_url | jsonify }},
      "summary": "",
      "content": {{ content | strip | jsonify }}
    }
    {% endcapture %}

    {% assign search_entries = search_entries | push: entry %}
  {% endfor %}
{% endfor %}

{% for year_group in site.data.talks %}
  {% for item in year_group.talks %}
    {% assign generated_item_anchor = year_group.year | append: '-' | append: forloop.index | append: '-' | append: item.title | slugify %}
    {% assign item_anchor = item.id | default: generated_item_anchor %}
    {% assign item_url = '/talks/#' | append: item_anchor %}
    {% assign item_topics = item.topics | default: empty %}
    {% include entry-date-vars.html date=item.date year=year_group.year %}
    {% assign item_topic_labels = '' | split: '' %}
    {% assign item_keywords = item.keywords | default: '' %}
    {% for topic_slug in item_topics %}
      {% assign topic_match = site.data.topics | where: 'slug', topic_slug | first %}
      {% assign topic_label = topic_slug %}
      {% if topic_match %}
        {% assign topic_label = topic_match.short_label | default: topic_match.label %}
      {% endif %}
      {% assign item_topic_labels = item_topic_labels | push: topic_label %}
    {% endfor %}
    {% capture item_meta -%}{{ item.venue }}{% if entry_date_display %} · {{ entry_date_display }}{% endif %}{%- endcapture -%}
    {% capture content -%}
      {{ item.title }}
      {{ item.speaker | strip_html }}
      {{ item.venue }}
      {{ item.date }}
      {{ entry_date_display }}
      {{ entry_date_iso }}
      {{ item.type }}
      {{ item.location }}
      {{ item_topics | join: ' ' }}
      {{ item_topic_labels | join: ' ' }}
      {{ item_keywords }}
      {{ item_url }}
      {% for link in item.links %}{{ link.label }} {{ link.type }} {{ link.url }} {% endfor %}
      {% for media in item.media %}{{ media.label }} {{ media.url }} {% endfor %}
    {%- endcapture -%}

    {% capture entry %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item_url | relative_url | jsonify }},
      "type": "Talk",
      "categories": "Talk",
      "tags": {{ item_topic_labels | join: ', ' | jsonify }},
      "keywords": {{ item_keywords | jsonify }},
      "meta": {{ item_meta | strip | jsonify }},
      "date": {{ entry_date_iso | jsonify }},
      "lang": "en",
      "translation_key": {{ item_url | jsonify }},
      "summary": "",
      "content": {{ content | strip | jsonify }}
    }
    {% endcapture %}

    {% assign search_entries = search_entries | push: entry %}
  {% endfor %}
{% endfor %}

[
  {{ search_entries | join: ',' }}
]
